{
  "$id": "frontend.ref.json",
  "type": "object",
  "properties": {
    "environment": {
      "type": "string"
    },
    "baseUrl": {
      "type": "string"
    },
    "apiBaseUrl": {
      "type": "string"
    },
    "isActiveEnvironment": {
      "type": "boolean"
    },
    "framework": {
      "type": "string",
      "enum": [
        "angular",
        "flutter",
        "react",
        "reactnative",
        "svelte",
        "vue"
      ]
    },
    "uiKit": {
      "type": "string",
      "enum": [
        "antdesign",
        "bootstrap",
        "material",
        "flowbite"
      ]
    },
    "logoPath": {
      "type": "string"
    },
    "faviconPath": {
      "type": "string"
    }
  },
  "required": [
    "framework",
    "uiKit",
    "isActiveEnvironment",
    "environment",
    "baseUrl",
    "apiBaseUrl"
  ]
}