{
  "$id": "project.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "skeleton": {
      "type": "string",
      "enum": ["backoffice", "marketplace", "landingPage", "socialNetwork"]
    },
    "flows": {
      "type": "object",
      "properties": {
        "authentication": {
          "type": "boolean"
        },
        "permission": {
          "type": "boolean"
        },
        "invitation": {
          "type": "object",
          "properties": {
            "mainUserEmail": {
              "type": "string"
            }
          },
          "required": ["mainUserEmail"]
        },
        "registration": {
          "type": "boolean"
        },
        "profiles": {
          "type": "object",
          "properties": {
            "personProfile": {
              "$ref": "form.ref.json"
            },
            "companyProfile": {
              "$ref": "form.ref.json"
            }
          }
        }
      }
    },
    "businessPlan": {
      "$ref": "business-plan.ref.json"
    },
    "businessRules": {
      "$ref": "business-rules.ref.json"
    },
    "frontend": {
      "$ref": "frontend.ref.json"
    },
    "backend": {
      "$ref": "backend.ref.json"
    },
    "deepseekIntegration": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "apiKey": {
            "type": "string"
          },
          "service": {
            "type": "string",
            "enum": ["embedding", "chat", "custom", "cost"]
          }
        },
        "required": ["apiKey", "service"]
      }
    },
    "mongodbIntegration": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "accountPublicKey": {
            "type": "string"
          },
          "accountPrivateKey": {
            "type": "string"
          },
          "organizationId": {
            "type": "string"
          },
          "groupId": {
            "type": "string"
          },
          "processId": {
            "type": "string"
          },
          "service": {
            "type": "string",
            "enum": ["embedding", "chat", "custom", "cost"]
          }
        },
        "required": ["service"]
      }
    },
    "e2e": {
      "$ref": "e2e.ref.json"
    },
    "modules": {
      "$ref": "module.ref.json"
    },
    "flowChart": {
      "$ref": "form-flowchart.ref.json"
    }
  },
  "required": ["id", "title", "description", "skeleton"]
}
