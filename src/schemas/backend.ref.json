{
  "$id": "backend.ref.json",
  "type": "object",
  "properties": {
    "framework": {
      "type": "string",
      "enum": ["functions", "lambda", "laravel", "nest", "dotnet"]
    },
    "database": {
      "type": "object",
      "properties": {
        "provider": {
          "type": "string",
          "enum": [
            "mariadb",
            "mongodb",
            "oracle",
            "postgresql",
            "mysql",
            "sqlserver",
            "sqlite"
          ]
        },
        "connectionString": { "type": "string" },
        "credentials": {
          "type": "object",
          "properties": {
            "username": { "type": "string" },
            "password": { "type": "string" },
            "host": { "type": "string" },
            "port": { "type": "integer" },
            "databaseName": { "type": "string" }
          },
          "required": ["username", "password", "host", "databaseName"]
        }
      },
      "required": ["provider", "connectionString", "credentials"]
    },
    "storage": {
      "type": "object",
      "properties": {
        "provider": { "type": "string", "enum": ["gcs", "s3", "azure"] },
        "publicBucketName": { "type": "string" },
        "privateBucketName": { "type": "string" },
        "credentials": {
          "type": "object",
          "properties": {
            "projectId": { "type": "string" },
            "privateKey": { "type": "string" },
            "clientEmail": { "type": "string" }
          },
          "required": ["projectId", "privateKey", "clientEmail"]
        }
      },
      "required": [
        "provider",
        "publicBucketName",
        "privateBucketName",
        "credentials"
      ]
    },
    "logging": {
      "type": "object",
      "properties": {
        "discordWebhookUrl": { "type": "string" }
      }
    },
    "whatsapp": {
      "type": "object",
      "properties": {
        "whatsappToken": { "type": "string" },
        "whatsappPhoneNumberId": { "type": "string" },
        "whatsappVerifyToken": { "type": "string" }
      }
    },
    "email": {
      "type": "object",
      "properties": {
        "smtpUser": { "type": "string" },
        "smtpPass": { "type": "string" },
        "smtpFrom": { "type": "string" }
      }
    },
    "marketplace": {
      "type": "object",
      "properties": {
        "paymentGateways": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "provider": { "type": "string" }
            }
          }
        },
        "productsAutocomplete": { "$ref": "form-autocomplete.ref.json" },
        "stockInEndpoint": { "type": "string" },
        "stockOutEndpoint": { "type": "string" },
        "productBaseUrl": { "type": "string" }
      },
      "required": ["paymentGateways", "productsAutocomplete", "stockInEndpoint", "stockOutEndpoint", "productBaseUrl"]
    },
    "service": {
      "type": "object",
      "properties": {
        "paymentGateways": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "provider": { "type": "string" }
            }
          }
        },
        "appointmentList": { "$ref": "list.ref.json" },
        "availabilityScheduleList": { "$ref": "list.ref.json" },
        "appointmentByAiList": { "$ref": "list.ref.json" }
      },
      "required": ["paymentGateways", "appointmentList", "availabilityScheduleList"]
    },
    "mercadoPagoIntegration": {
      "type": "object",
      "properties": {
        "publicKey": { "type": "string" },
        "accessToken": { "type": "string" },
        "appId": { "type": "string" },
        "userId": { "type": "string" },
        "testUserId": { "type": "string" },
        "password": { "type": "string" },
        "verificationCode": { "type": "string" },
        "testSellerSettings": {
          "type": "object",
          "properties": {
            "userId": { "type": "string" },
            "user": { "type": "string" },
            "password": { "type": "string" },
            "verificationCode": { "type": "string" }
          },
          "required": ["userId", "user", "password", "verificationCode"]
        },
        "testBuyerSettings": {
          "type": "object",
          "properties": {
            "userId": { "type": "string" },
            "user": { "type": "string" },
            "password": { "type": "string" },
            "verificationCode": { "type": "string" }
          },
          "required": ["userId", "user", "password", "verificationCode"]
        }
      }
    }
  },
  "required": ["framework", "database", "jwtSecret"]
}
