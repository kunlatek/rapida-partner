{
  "$id": "form.ref.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "componentType": {
      "const": "form"
    },
    "id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "icon": {
      "type": "string"
    },
    "guards": {
      "type": "string",
      "enum": [
        "isAuthenticated",
        "isAuthorized"
      ]
    },
    "businessRules": {
      "$ref": "business-rules.ref.json"
    },
    "elements": {
      "$ref": "form-one-of.ref.json"
    },
    "userStory": {
      "type": "string"
    },
    "contracts": {
      "type": "array",
      "items": {
        "$ref": "form-contract.ref.json"
      }
    },
    "publicContracts": {
      "type": "array",
      "items": {
        "$ref": "form-public-contract.ref.json"
      }
    },
    "flowChart": {
      "$ref": "form-flowchart.ref.json"
    }
  },
  "required": [
    "componentType",
    "id",
    "title",
    "elements",
    "contracts"
  ]
}